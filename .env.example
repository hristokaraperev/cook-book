# Copy this file to .env.local and fill in your credentials

# Google OAuth2 Client ID (from Google Cloud Console)
# See GOOGLE_SETUP.md for setup instructions
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# USDA FoodData Central API key
# Register for free at: https://fdc.nal.usda.gov/api-key-signup.html
# Uses DEMO_KEY if omitted (very limited rate limits)
VITE_USDA_API_KEY=DEMO_KEY
